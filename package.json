{
  "name": "resonite-profile",
  "version": "1.0.0",
  "description": "Resonite user search application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'do nothing'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "dev:worker": "wrangler dev",
    "deploy:worker": "wrangler deploy",
    "test:worker": "node --experimental-default-type=module --test tests/worker.test.mjs",
    "test:staging-smoke": "bash scripts/staging-smoke-check.sh",
    "test:staging-smoke:dry": "DRY_RUN=1 bash scripts/staging-smoke-check.sh",
    "test:staging-smoke:report": "STAGING_SMOKE_REPORT=docs/staging-smoke-report.md bash scripts/staging-smoke-check.sh",
    "test:staging-smoke:json": "STAGING_SMOKE_JSON=docs/staging-smoke-report.json bash scripts/staging-smoke-check.sh",
    "test:staging-smoke:strict:dry": "STAGING_REQUIRE_USER_DETAIL=1 DRY_RUN=1 bash scripts/staging-smoke-check.sh",
    "test:staging-smoke:env": "bash scripts/run-staging-smoke-from-env.sh docs/staging-smoke.env.example normal",
    "test:staging-smoke:env:strict": "bash scripts/run-staging-smoke-from-env.sh docs/staging-smoke.env.example strict",
    "init:staging-smoke-env": "bash scripts/init-staging-smoke-env.sh .env.staging-smoke",
    "test:staging-smoke:env:validate": "bash scripts/validate-staging-smoke-env.sh .env.staging-smoke",
    "test:staging-smoke:pipeline": "bash scripts/run-staging-smoke-pipeline.sh .env.staging-smoke normal",
    "test:staging-smoke:pipeline:strict": "bash scripts/run-staging-smoke-pipeline.sh .env.staging-smoke strict",
    "test:staging-smoke:doctor": "bash scripts/doctor-staging-smoke.sh",
    "test:staging-smoke:preflight": "bash scripts/preflight-staging-smoke.sh",
    "test:staging-smoke:env:dry": "DRY_RUN=1 bash scripts/run-staging-smoke-from-env.sh docs/staging-smoke.env.example normal",
    "test:staging-smoke:env:strict:dry": "DRY_RUN=1 bash scripts/run-staging-smoke-from-env.sh docs/staging-smoke.env.example strict",
    "test:alerts:validate": "bash scripts/validate-cloudflare-alert-thresholds.sh docs/cloudflare-alert-thresholds-template.json",
    "test:worker:readiness": "bash scripts/check-worker-rollout-readiness.sh",
    "lint:scripts:rollout": "bash scripts/lint-rollout-scripts.sh",
    "progress:worker-rollout": "bash scripts/show-worker-rollout-progress.sh README.md",
    "progress:worker-rollout:json": "PROGRESS_JSON=1 bash scripts/show-worker-rollout-progress.sh README.md",
    "verify:worker-rollout:docs": "bash scripts/verify-worker-rollout-docs.sh README.md package.json docs/worker-operations-checklist.md",
    "verify:worker-rollout:docs:json": "DOCS_VERIFY_JSON=docs/worker-rollout-docs-verify.json bash scripts/verify-worker-rollout-docs.sh README.md package.json docs/worker-operations-checklist.md",
    "test:worker:readiness:ci": "bash scripts/run-worker-rollout-ci-check.sh",
    "test:worker:readiness:ci:keep": "KEEP_ARTIFACTS=1 bash scripts/run-worker-rollout-ci-check.sh",
    "deps:worker-rollout": "bash scripts/ensure-worker-rollout-deps.sh",
    "verify:worker-rollout:progress": "bash scripts/validate-worker-rollout-progress.sh README.md",
    "report:worker-rollout:open-items": "bash scripts/report-worker-rollout-open-items.sh README.md",
    "report:worker-rollout:open-items:json": "OPEN_ITEMS_JSON=docs/worker-rollout-open-items.json bash scripts/report-worker-rollout-open-items.sh README.md",
    "report:worker-rollout:open-items:strict": "REQUIRE_NO_OPEN_ITEMS=1 bash scripts/report-worker-rollout-open-items.sh README.md",
    "report:worker-rollout:open-items:json:strict": "REQUIRE_NO_OPEN_ITEMS=1 OPEN_ITEMS_JSON=docs/worker-rollout-open-items.json bash scripts/report-worker-rollout-open-items.sh README.md",
    "test:worker:readiness:ci:strict": "REQUIRE_NO_OPEN_ITEMS=1 bash scripts/run-worker-rollout-ci-check.sh",
    "test:worker:readiness:ci:strict:keep": "KEEP_ARTIFACTS=1 REQUIRE_NO_OPEN_ITEMS=1 bash scripts/run-worker-rollout-ci-check.sh",
    "verify:worker-rollout:evidence": "bash scripts/validate-worker-rollout-evidence.sh docs/worker-rollout-evidence.md",
    "verify:worker-rollout:evidence:strict": "REQUIRE_EVIDENCE_COMPLETE=1 bash scripts/validate-worker-rollout-evidence.sh docs/worker-rollout-evidence.md",
    "report:worker-rollout:status": "bash scripts/report-worker-rollout-status.sh README.md docs/worker-rollout-evidence.md",
    "report:worker-rollout:status:json": "ROLLOUT_STATUS_JSON=docs/worker-rollout-status.json bash scripts/report-worker-rollout-status.sh README.md docs/worker-rollout-evidence.md",
    "report:worker-rollout:status:md": "ROLLOUT_STATUS_MARKDOWN=docs/worker-rollout-status.md bash scripts/report-worker-rollout-status.sh README.md docs/worker-rollout-evidence.md",
    "sync:worker-rollout:open-items": "bash scripts/sync-worker-rollout-open-items.sh README.md docs/worker-rollout-evidence.md",
    "sync:worker-rollout:open-items:apply": "APPLY_CHANGES=1 bash scripts/sync-worker-rollout-open-items.sh README.md docs/worker-rollout-evidence.md",
    "sync:worker-rollout:open-items:strict": "REQUIRE_SYNC_READY=1 bash scripts/sync-worker-rollout-open-items.sh README.md docs/worker-rollout-evidence.md",
    "report:worker-rollout:overview": "bash scripts/report-worker-rollout-overview.sh README.md docs/worker-rollout-evidence.md",
    "report:worker-rollout:overview:json": "ROLLOUT_OVERVIEW_JSON=docs/worker-rollout-overview.json bash scripts/report-worker-rollout-overview.sh README.md docs/worker-rollout-evidence.md",
    "sync:worker-rollout:open-items:apply:strict": "APPLY_CHANGES=1 REQUIRE_SYNC_READY=1 bash scripts/sync-worker-rollout-open-items.sh README.md docs/worker-rollout-evidence.md",
    "test:worker:readiness:strict": "REQUIRE_NO_OPEN_ITEMS=1 REQUIRE_EVIDENCE_COMPLETE=1 bash scripts/check-worker-rollout-readiness.sh"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "nodemon": "^3.0.1",
    "prettier": "^3.6.0",
    "resonitelink.js": "file:./ResoniteLink.js",
    "wrangler": "^4.33.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
