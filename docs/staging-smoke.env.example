# Run `npm run test:staging-smoke:env:validate` after editing this file.
# Copy this file and load it before running staging smoke checks.
# Example:
#   set -a; source docs/staging-smoke.env.example; set +a
#   npm run test:staging-smoke

# Required (unless using *:dry scripts)
STAGING_BASE_URL="https://your-staging-worker.workers.dev"

# Optional request context
STAGING_ORIGIN="https://your-frontend.example.com"
STAGING_TEST_NAME="cloud"
STAGING_TEST_USER_ID=""

# Optional stricter validation
STAGING_REQUIRED_HEADERS="x-request-id,server-timing"
STAGING_EXPECT_HEALTH="200"
STAGING_EXPECT_USERS_SEARCH="200"
STAGING_EXPECT_USER_DETAIL="200"
STAGING_EXPECT_SESSIONS="200"
STAGING_REQUIRE_USER_DETAIL="0"

# Optional output artifacts
STAGING_SMOKE_REPORT="docs/staging-smoke-report.md"
STAGING_SMOKE_JSON="docs/staging-smoke-report.json"
